{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Parcel Precheck Sample Set",
  "type": "object",
  "required": [
    "dataset_name",
    "version",
    "samples"
  ],
  "properties": {
    "dataset_name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "sample_id",
          "parcel_id",
          "image_path",
          "text_description",
          "land_type",
          "metadata",
          "expected_result",
          "applied_rule_ids"
        ],
        "properties": {
          "sample_id": {
            "type": "string"
          },
          "parcel_id": {
            "type": "string"
          },
          "image_path": {
            "type": "string"
          },
          "text_description": {
            "type": "string"
          },
          "land_type": {
            "type": "string"
          },
          "metadata": {
            "type": "object"
          },
          "expected_result": {
            "type": "object",
            "required": [
              "parcel_id",
              "is_abnormal",
              "issue_type",
              "reason",
              "evidence",
              "confidence",
              "requires_manual_review",
              "rule_hits"
            ],
            "properties": {
              "parcel_id": {
                "type": "string"
              },
              "is_abnormal": {
                "type": "boolean"
              },
              "issue_type": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              },
              "evidence": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "requires_manual_review": {
                "type": "boolean"
              },
              "rule_hits": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "applied_rule_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
